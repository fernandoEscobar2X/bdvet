---
import "swiper/css";
import "swiper/css/effect-fade";
import "swiper/css/navigation";
import "swiper/css/pagination";

import "@/styles/tokens.css";
import "@/styles/global.css";
import "@/styles/motion.css";

import scriptUrl from "@/scripts/storefront.ts?url";
import AnnouncementBar from "@/components/shell/AnnouncementBar.astro";
import Header from "@/components/shell/Header.astro";
import MobileMenu from "@/components/shell/MobileMenu.astro";
import Footer from "@/components/shell/Footer.astro";
import CartDrawer from "@/components/cart/CartDrawer.astro";
import { productsContent, siteContent } from "@/lib/content";

type Props = {
  title?: string;
  description?: string;
  image?: string;
};

const {
  title = siteContent.title,
  description = siteContent.description,
  image = siteContent.seoImage,
} = Astro.props as Props;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site) : Astro.url;
const storefrontPayload = {
  products: productsContent,
  site: {
    businessName: siteContent.businessName,
    phoneRaw: siteContent.phoneRaw,
    calendlyUrl: siteContent.calendlyUrl,
  },
};
---
<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#17324D" />
    <link rel="canonical" href={canonical.toString()} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;500;600;700&family=Montserrat:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:image" content={new URL(image, Astro.site ?? Astro.url).toString()} />
  </head>
  <body>
    <script is:inline define:vars={{ storefrontPayload }}>
      window.__BORDERVET__ = storefrontPayload;
    </script>

    <div class="site-shell">
      <AnnouncementBar />
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>

    <MobileMenu />
    <CartDrawer />
    <div class="toast" data-toast data-visible="false"></div>

    <script is:inline type="module" src={scriptUrl}></script>
  </body>
</html>
