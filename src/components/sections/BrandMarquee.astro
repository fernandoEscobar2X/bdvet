---
const brands = [
  { name: "Royal Canin", logo: "/images/brands/royal-canin.svg", width: 198 },
  { name: "Purina Pro Plan", logo: "/images/brands/purina-pro-plan.svg", width: 214 },
  { name: "Hill's", logo: "/images/brands/hills.svg", width: 162 },
  { name: "Frontline", logo: "/images/brands/frontline.svg", width: 178 },
  { name: "Seresto", logo: "/images/brands/seresto.svg", width: 172 },
  { name: "Catsan", logo: "/images/brands/catsan.svg", width: 164 },
  { name: "Nupec", logo: "/images/brands/nupec.svg", width: 164 },
  { name: "Bravecto", logo: "/images/brands/bravecto.svg", width: 186 },
] as const;

---
<section class="brand-marquee" aria-labelledby="brand-marquee-title">
  <div class="container-shell">
    <div class="brand-marquee__shell">
      <h2 id="brand-marquee-title" class="sr-only">Marcas presentes en BorderVet</h2>
      <div class="brand-marquee__band" data-brand-marquee>
        <div class="brand-marquee__viewport">
          <div class="brand-marquee__track" data-brand-track>
            <ul class="brand-marquee__set" data-brand-set aria-label="Marcas destacadas de BorderVet">
              {brands.map((brand) => (
                <li class="brand-marquee__item" style={`--brand-width:${brand.width}px;`}>
                  <img
                    class="brand-marquee__logo"
                    src={brand.logo}
                    alt={brand.name}
                    width={brand.width}
                    height="72"
                    loading="eager"
                    decoding="async"
                  />
                </li>
              ))}
            </ul>

            <ul class="brand-marquee__set" aria-hidden="true">
              {brands.map((brand) => (
                <li class="brand-marquee__item" style={`--brand-width:${brand.width}px;`}>
                  <img
                    class="brand-marquee__logo"
                    src={brand.logo}
                    alt=""
                    aria-hidden="true"
                    width={brand.width}
                    height="72"
                    loading="eager"
                    decoding="async"
                  />
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .brand-marquee {
    position: relative;
    padding: 1.4rem 0 2.4rem;
  }

  .brand-marquee__shell {
    position: relative;
  }

  .brand-marquee__band {
    position: relative;
  }

  .brand-marquee__viewport {
    position: relative;
    overflow: hidden;
    mask-image: var(--mask-fade-x);
    -webkit-mask-image: var(--mask-fade-x);
  }

  .brand-marquee__track {
    display: flex;
    align-items: center;
    width: max-content;
    gap: 0;
    will-change: transform;
    transform: translate3d(0, 0, 0);
  }

  .brand-marquee__set {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    width: max-content;
    margin: 0;
    padding: 0;
    list-style: none;
    flex-shrink: 0;
  }

  .brand-marquee__item {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 6rem;
    min-width: calc(var(--brand-width) + 4rem);
    padding: 1.25rem 2rem;
    white-space: nowrap;
    position: relative;
    flex: 0 0 auto;
  }

  .brand-marquee__item::after {
    content: "";
    position: absolute;
    top: 50%;
    right: 0;
    width: 1px;
    height: 2.4rem;
    background: linear-gradient(180deg, transparent, rgba(30, 26, 71, 0.14), transparent);
    transform: translateY(-50%);
  }

  .brand-marquee__item::before {
    content: "";
    position: absolute;
    top: 50%;
    right: -2px;
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: var(--color-accent-bright);
    transform: translateY(-50%) scale(0);
    opacity: 0;
    transition:
      transform var(--transition-base),
      opacity var(--transition-base);
    box-shadow: 0 0 12px rgba(255, 196, 70, 0.55);
  }

  .brand-marquee__item:hover::before {
    transform: translateY(-50%) scale(1);
    opacity: 0.9;
  }

  .brand-marquee__logo {
    display: block;
    width: auto;
    max-width: min(100%, var(--brand-width));
    height: clamp(2.4rem, 3.1vw, 3.15rem);
    object-fit: contain;
    opacity: 0.62;
    filter: grayscale(1) contrast(1.02) brightness(0.96);
    transition:
      opacity var(--transition-base),
      filter var(--transition-base),
      transform var(--transition-base);
    transform: translate3d(0, 0, 0);
    will-change: opacity, filter, transform;
  }

  [data-brand-marquee]:hover .brand-marquee__logo {
    opacity: 0.85;
  }

  .brand-marquee__item:hover .brand-marquee__logo {
    opacity: 1;
    filter: grayscale(0) contrast(1.04) brightness(1);
    transform: translate3d(0, -2px, 0) scale(1.06);
  }

  @media (max-width: 820px) {
    .brand-marquee {
      padding: 1rem 0 1.6rem;
    }

    .brand-marquee__item {
      min-height: 5rem;
      min-width: calc(var(--brand-width) + 2.1rem);
      padding: 1rem 1.05rem;
    }

    .brand-marquee__item::after {
      height: 1.95rem;
    }

    .brand-marquee__logo {
      height: 2.1rem;
      opacity: 0.72;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-marquee__logo {
      filter: none;
      opacity: 0.85;
    }
  }
</style>
