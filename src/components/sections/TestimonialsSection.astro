---
import Icon from "@/components/ui/Icon.astro";
import { testimonialsContent } from "@/lib/content";
---
<section
  class="testimonials-premium section-block"
  aria-labelledby="testimonials-premium-title"
>
  <div class="container-shell">
    <div class="testimonials-premium__shell">
      <div class="testimonials-premium__intro" data-reveal="right">
        <span class="eyebrow">Clientes BorderVet</span>
        <h2 id="testimonials-premium-title" class="testimonials-premium__title">
          Familias que ya confian su mascota a BorderVet
        </h2>
        <p class="testimonials-premium__description">
          Perros y gatos en Tijuana que recibieron lo que necesitaban, con la atencion que merecian. Historias reales de clientes reales.
        </p>

        <div class="testimonials-premium__score">
          <strong>5.0</strong>
          <div class="testimonials-premium__stars" aria-label="Calificacion promedio de 5 estrellas">
            {Array.from({ length: 5 }).map(() => (
              <Icon name="star" size={18} />
            ))}
          </div>
          <span>Promedio en reseñas de clientes</span>
        </div>
      </div>

      <div class="testimonials-premium__slider" data-reveal="left">
        <div class="swiper js-testimonial-swiper">
          <div class="swiper-wrapper">
            {testimonialsContent.map((testimonial) => (
              <article class="swiper-slide testimonials-premium__card">
                <div class="testimonials-premium__quote-mark">"</div>

                <div class="testimonials-premium__card-stars" aria-label={`${testimonial.rating} estrellas`}>
                  {Array.from({ length: testimonial.rating }).map(() => (
                    <Icon name="star" size={15} />
                  ))}
                </div>

                <p class="testimonials-premium__text">{testimonial.texto}</p>

                <div class="testimonials-premium__author">
                  <strong>{testimonial.nombre}</strong>
                  <span>{testimonial.mascota} · {testimonial.ubicacion}</span>
                </div>
              </article>
            ))}
          </div>

          <div class="swiper-pagination js-testimonial-pagination testimonials-premium__pagination"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials-premium {
    position: relative;
    background:
      linear-gradient(180deg, rgba(247, 239, 228, 0.46), rgba(255, 255, 255, 0));
  }

  .testimonials-premium__shell {
    display: grid;
    grid-template-columns: minmax(0, 0.75fr) minmax(0, 1.25fr);
    gap: clamp(1.4rem, 3vw, 2.4rem);
    align-items: start;
  }

  .testimonials-premium__intro {
    min-width: 0;
    padding: 2rem;
    border-radius: 2.3rem;
    background:
      linear-gradient(145deg, rgba(30, 26, 71, 1), rgba(22, 18, 56, 1));
    box-shadow: 0 20px 54px rgba(17, 17, 17, 0.14);
  }

  .testimonials-premium__title {
    margin: 1rem 0 1rem;
    color: #ffffff;
    font-family: var(--font-display);
    font-size: clamp(1.95rem, 3.4vw, 3rem);
    line-height: 1;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .testimonials-premium__description {
    margin: 0;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.8;
  }

  .testimonials-premium__score {
    display: grid;
    gap: 0.5rem;
    margin-top: 1.6rem;
    color: #ffffff;
  }

  .testimonials-premium__score strong {
    font-family: var(--font-display);
    font-size: 2.5rem;
    line-height: 1;
  }

  .testimonials-premium__stars {
    display: inline-flex;
    gap: 0.28rem;
    color: var(--color-accent-bright);
  }

  .testimonials-premium__score span {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.92rem;
  }

  .testimonials-premium__slider {
    min-width: 0;
  }

  .testimonials-premium__card {
    position: relative;
    min-height: 100%;
    padding: 1.6rem 1.75rem;
    border-radius: 1.5rem;
    background: #ffffff;
    box-shadow: 0 14px 36px rgba(17, 17, 17, 0.07);
  }

  .testimonials-premium__quote-mark {
    position: absolute;
    top: 1rem;
    right: 1.15rem;
    color: rgba(30, 26, 71, 0.08);
    font-family: var(--font-display);
    font-size: 5rem;
    line-height: 1;
  }

  .testimonials-premium__card-stars {
    display: inline-flex;
    gap: 0.3rem;
    color: var(--color-accent-bright);
  }

  .testimonials-premium__text {
    margin: 1rem 0 1.25rem;
    color: var(--color-heading);
    font-size: 1rem;
    line-height: 1.85;
  }

  .testimonials-premium__author {
    display: grid;
    gap: 0.25rem;
  }

  .testimonials-premium__author strong {
    color: var(--color-heading);
    font-size: 1rem;
  }

  .testimonials-premium__author span {
    color: var(--color-meta);
    font-size: 0.9rem;
  }

  .testimonials-premium__pagination {
    margin-top: 1.25rem;
  }

  .testimonials-premium__pagination :global(.swiper-pagination-bullet) {
    width: 0.7rem;
    height: 0.7rem;
    background: rgba(30, 26, 71, 0.18);
    opacity: 1;
  }

  .testimonials-premium__pagination :global(.swiper-pagination-bullet-active) {
    width: 1.8rem;
    border-radius: var(--radius-pill);
    background: var(--color-accent);
  }

  @media (max-width: 980px) {
    .testimonials-premium__shell {
      grid-template-columns: 1fr;
    }
  }
</style>
