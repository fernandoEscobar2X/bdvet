---
import Button from "@/components/ui/Button.astro";
import Icon from "@/components/ui/Icon.astro";
import { buildMapsEmbedUrl } from "@/integrations/maps";
import { contactContent, siteContent } from "@/lib/content";

const contactCards = [
  {
    icon: "map-pin",
    title: contactContent.addressTitle,
    detail: contactContent.addressLine,
  },
  {
    icon: "whatsapp",
    title: contactContent.phoneDisplay,
    detail: "Pedidos, dudas y seguimiento por el canal mas directo.",
  },
  {
    icon: "mail",
    title: contactContent.email,
    detail: "Escribenos para consultas, facturas o informacion general.",
  },
  {
    icon: "clock",
    title: contactContent.hours,
    detail: "Horario ideal de respuesta para atencion y consulta.",
  },
] as const;
---
<section class="contact-premium section-block" id="contacto" aria-labelledby="contact-premium-title">
  <div class="container-shell">
    <div class="contact-premium__shell">
      <div class="contact-premium__intro" data-reveal="right">
        <span class="eyebrow">Ubicacion y contacto</span>
        <h2 id="contact-premium-title" class="contact-premium__title">
          Estamos en Tijuana y siempre disponibles para tu mascota
        </h2>
        <p class="contact-premium__description">
          Escribenos por WhatsApp, agenda una consulta o visitanos. Respuesta rapida y atencion real, sin rodeos.
        </p>

        <div class="contact-premium__actions">
          <Button href={`https://wa.me/${siteContent.phoneRaw}`} target="_blank" variant="primary">
            WhatsApp directo
          </Button>
          <Button href={siteContent.calendlyUrl} target="_blank" variant="surface">
            Abrir Calendly
          </Button>
        </div>

        <div class="contact-premium__cards">
          {contactCards.map((card) => (
            <article class="contact-premium__card">
              <span class="contact-premium__icon">
                <Icon name={card.icon} size={18} />
              </span>
              <div>
                <h3>{card.title}</h3>
                <p>{card.detail}</p>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="contact-premium__map" data-reveal="left">
        <div class="contact-premium__map-frame" data-map-facade>
          <div class="contact-premium__map-placeholder" aria-hidden="true">
            <Icon name="map-pin" size={28} />
            <strong>BorderVet · Tijuana</strong>
            <span>{contactContent.addressLine}</span>
          </div>
          <div class="contact-premium__map-actions">
            <button
              class="btn btn-surface contact-premium__map-load"
              type="button"
              data-map-load
              data-map-src={buildMapsEmbedUrl(contactContent.mapsEmbed)}
            >
              Cargar mapa interactivo
            </button>
            <a
              class="btn btn-link contact-premium__map-open"
              href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(contactContent.addressLine)}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              Abrir en Google Maps
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-premium__shell {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: clamp(1.4rem, 3vw, 2.5rem);
    align-items: start;
  }

  .contact-premium__intro {
    min-width: 0;
    padding: 2rem;
    border-radius: 2.3rem;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 1), rgba(248, 246, 242, 0.98));
    border: 1px solid rgba(231, 223, 210, 0.84);
    box-shadow: var(--shadow-card);
  }

  .contact-premium__title {
    margin: 1rem 0 1rem;
    color: var(--color-heading);
    font-family: var(--font-display);
    font-size: clamp(1.95rem, 3.6vw, 3.1rem);
    line-height: 1;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .contact-premium__description {
    margin: 0;
    color: var(--color-text);
    line-height: 1.8;
  }

  .contact-premium__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.5rem;
  }

  .contact-premium__cards {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    margin-top: 1.5rem;
    border-top: 1px solid rgba(231, 223, 210, 0.56);
  }

  .contact-premium__card {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(231, 223, 210, 0.56);
  }

  .contact-premium__card:last-child {
    border-bottom: none;
  }

  .contact-premium__icon {
    display: inline-grid;
    place-items: center;
    width: 2.7rem;
    height: 2.7rem;
    border-radius: 1rem;
    background: rgba(30, 26, 71, 0.08);
    color: var(--color-primary);
    flex: 0 0 auto;
  }

  .contact-premium__card h3 {
    margin: 0 0 0.35rem;
    color: var(--color-heading);
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.14;
  }

  .contact-premium__card p {
    margin: 0;
    color: var(--color-text);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .contact-premium__map {
    min-width: 0;
    position: sticky;
    top: clamp(1.5rem, 4vh, 2.5rem);
  }

  .contact-premium__map-frame {
    position: relative;
    height: clamp(28rem, 58vh, 38rem);
    overflow: hidden;
    border-radius: 2.3rem 2.3rem 5.5rem 2.3rem;
    border: 1px solid rgba(231, 223, 210, 0.84);
    box-shadow: var(--shadow-card);
    background:
      radial-gradient(circle at 32% 28%, rgba(255, 255, 255, 0.5), transparent 38%),
      linear-gradient(160deg, rgba(224, 242, 255, 0.85), rgba(247, 239, 228, 0.65));
  }

  .contact-premium__map-frame iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .contact-premium__map-placeholder {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    align-content: center;
    gap: 0.45rem;
    text-align: center;
    padding: 1.5rem;
    color: var(--color-primary);
    pointer-events: none;
  }

  .contact-premium__map-placeholder strong {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--color-heading);
  }

  .contact-premium__map-placeholder span {
    font-size: 0.92rem;
    color: var(--color-text);
    max-width: 22rem;
    line-height: 1.55;
  }

  .contact-premium__map-actions {
    position: absolute;
    bottom: 1.2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    pointer-events: auto;
  }

  .contact-premium__map-load {
    min-width: 14rem;
    background: rgba(255, 255, 255, 0.94);
  }

  .contact-premium__map-frame[data-map-loaded="true"] .contact-premium__map-placeholder,
  .contact-premium__map-frame[data-map-loaded="true"] .contact-premium__map-actions {
    display: none;
  }

  @media (max-width: 980px) {
    .contact-premium__shell {
      grid-template-columns: 1fr;
    }

    .contact-premium__map {
      position: static;
    }

    .contact-premium__map-frame {
      height: clamp(22rem, 42vh, 28rem);
    }
  }

  @media (max-width: 720px) {
    .contact-premium__cards {
      grid-template-columns: 1fr;
    }

    .contact-premium__actions {
      flex-direction: column;
    }

    .contact-premium__map-frame {
      border-radius: 1.6rem;
    }

    .contact-premium__map-actions {
      bottom: 0.9rem;
    }

    .contact-premium__map-load {
      min-width: 12rem;
    }
  }
</style>

<script is:inline>
  (() => {
    const facade = document.querySelector('[data-map-facade]');
    if (!facade) return;
    const loadBtn = facade.querySelector('[data-map-load]');
    if (!(loadBtn instanceof HTMLElement)) return;
    loadBtn.addEventListener('click', () => {
      const src = loadBtn.dataset.mapSrc;
      if (!src) return;
      const iframe = document.createElement('iframe');
      iframe.src = src;
      iframe.title = 'Mapa de BorderVet en Tijuana';
      iframe.loading = 'eager';
      iframe.referrerPolicy = 'no-referrer-when-downgrade';
      facade.appendChild(iframe);
      facade.setAttribute('data-map-loaded', 'true');
    }, { once: true });
  })();
</script>
