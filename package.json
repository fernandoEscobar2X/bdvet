{
  "name": "bordervet-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @bordervet/web dev",
    "build": "pnpm -r --if-present build",
    "check": "pnpm -r --if-present check",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "web:build": "pnpm --filter @bordervet/web build",
    "web:check": "pnpm --filter @bordervet/web check"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  }
}
