---
import Button from "@/components/ui/Button.astro";
import Icon from "@/components/ui/Icon.astro";

const featureBullets = [
  "Seleccion pensada para perros y gatos",
  "Compra guiada con criterio veterinario",
  "Atencion clara antes de decidir",
];
const HERO_PLACEHOLDER = "/images/placeholders/hero-placeholder.svg";
const heroFallback = `this.onerror=null;this.src='${HERO_PLACEHOLDER}'`;
---
<section class="promo-feature section-block" aria-labelledby="promo-feature-title">
  <div class="container-shell">
    <div class="promo-feature__shell">
      <div class="promo-feature__visual" data-reveal="right">
        <div class="promo-feature__image-frame">
          <img
            src="/images/hero/hero-products.svg"
            alt=""
            width="600"
            height="540"
            loading="lazy"
            decoding="async"
            onerror={heroFallback}
          />
        </div>
      </div>

      <div class="promo-feature__content" data-reveal="left">
        <span class="eyebrow">Criterio BorderVet</span>
        <h2 id="promo-feature-title" class="promo-feature__title">
          Productos elegidos con criterio veterinario
        </h2>
        <p class="promo-feature__description">
          En BorderVet no vendemos cualquier cosa. Cada producto pasa por un filtro veterinario antes de llegar al catalogo, para que compres con mas seguridad y menos dudas.
        </p>

        <ul class="promo-feature__list">
          {featureBullets.map((bullet) => (
            <li>
              <Icon name="shield" size={16} />
              <span>{bullet}</span>
            </li>
          ))}
        </ul>

        <div class="promo-feature__actions">
          <Button href="/catalogo" variant="primary">Ver catalogo</Button>
          <Button href="#asesoria" variant="surface">Pedir asesoria</Button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .promo-feature {
    position: relative;
  }

  .promo-feature__shell {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
    align-items: center;
    padding: clamp(1.25rem, 2vw, 1.5rem);
    border-radius: 2.4rem;
    background:
      radial-gradient(circle at top right, rgba(191, 136, 87, 0.16), transparent 28%),
      linear-gradient(145deg, rgba(247, 239, 228, 0.98), rgba(255, 255, 255, 0.98));
    border: 1px solid rgba(231, 223, 210, 0.9);
    box-shadow: var(--shadow-card);
  }

  .promo-feature__visual,
  .promo-feature__content {
    min-width: 0;
  }

  .promo-feature__image-frame {
    position: relative;
    min-height: 28rem;
    display: grid;
    place-items: center;
    overflow: hidden;
    border-radius: 2rem 2rem 5rem 2rem;
    background:
      radial-gradient(circle at 22% 22%, rgba(255, 255, 255, 0.62), transparent 18%),
      linear-gradient(145deg, rgba(224, 242, 255, 1), rgba(255, 255, 255, 0.96));
    box-shadow: 0 24px 60px rgba(17, 17, 17, 0.12);
  }

  .promo-feature__image-frame img {
    width: min(88%, 30rem);
    height: auto;
    object-fit: contain;
  }

  .promo-feature__title {
    margin: 0.95rem 0 1rem;
    color: var(--color-heading);
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.7vw, 3.3rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .promo-feature__description {
    margin: 0;
    color: var(--color-text);
    font-size: 1.03rem;
    line-height: 1.85;
  }

  .promo-feature__list {
    display: grid;
    gap: 0.85rem;
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .promo-feature__list li {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--color-heading);
    font-weight: 600;
  }

  .promo-feature__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.8rem;
  }

  @media (max-width: 900px) {
    .promo-feature__shell {
      grid-template-columns: 1fr;
    }

    .promo-feature__image-frame {
      min-height: 22rem;
    }
  }

  @media (max-width: 640px) {
    .promo-feature__actions {
      flex-direction: column;
    }

    .promo-feature__actions :global(.btn) {
      width: 100%;
    }
  }
</style>
