---
import BaseLayout from "@/layouts/BaseLayout.astro";
---
<BaseLayout title="Página no encontrada — BorderVet" description="La página que buscas no existe o cambió de lugar.">
  <section class="section-block">
    <div class="container-shell">
      <article class="policy-card" style="text-align:center;">
        <span class="eyebrow">404</span>
        <h1 class="page-title" style="margin-top:1rem;">La ruta que buscas no existe</h1>
        <p class="product-copy" style="max-width:36rem;margin:1rem auto 0;">
          Vuelve al inicio o entra al catálogo para seguir explorando la experiencia BorderVet.
        </p>
        <div style="display:flex;justify-content:center;gap:0.8rem;flex-wrap:wrap;margin-top:1.8rem;">
          <a class="btn btn-primary" href="/">Ir al inicio</a>
          <a class="btn btn-surface" href="/catalogo">Abrir catálogo</a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
